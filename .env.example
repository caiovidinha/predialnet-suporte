# Copy this file to .env.local and fill in the values

# Base da API Predialnet (produção: https://appgw.predialnet.com.br)
API_BASE_URL=https://appgw.predialnet.com.br

# Token de operador injetado server-side no header x-access-token
ADMIN_BYPASS_TOKEN=

# Segredo usado pelo iron-session para assinar o cookie (>= 32 chars)
SESSION_SECRET=

# Senha de acesso ao painel de suporte
DASHBOARD_PASSWORD=
